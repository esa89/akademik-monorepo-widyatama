# =============================================================================
# API IDENTITY - Environment Configuration
# =============================================================================

# Application
PORT=3013
NODE_ENV=development

# CORS
CORS_ORIGINS=http://localhost:5174,http://localhost:6174,http://localhost:5175

# Authentik SSO
AUTHENTIK_URL=http://localhost:9010
AUTHENTIK_CLIENT_ID=fe-identity
AUTHENTIK_CLIENT_SECRET=widyatama-client-secret-change-me-in-production

# Authentik Admin API Token
# Dapatkan dari: Authentik Admin → Admin Interface → System → Tokens
# Buat token baru dengan intent "API" untuk user authentik
AUTHENTIK_ADMIN_TOKEN=your-authentik-admin-api-token-here

# Frontend URLs
FE_IDENTITY_URL=http://localhost:5174
FE_DOSEN_URL=http://localhost:6173
