// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CplCategory {
  SIKAP
  PENGETAHUAN
  KETERAMPILAN_UMUM
  KETERAMPILAN_KHUSUS
}

enum VisiMisiType {
  VISI
  MISI
}

enum AssessmentType {
  QUIZ
  ASSIGNMENT
  PRACTICUM
  PROJECT
  PRESENTATION
  UTS
  UAS
  OTHER
}

model AssessmentComponent {
  id           String                       @id @default(uuid())
  code         String                       @unique
  name         String
  description  String?
  isActive     Boolean                      @default(true)
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt
  weightEntries CourseCpmkAssessmentWeight[]

  @@index([code])
  @@index([name])
  @@index([isActive])
  @@map("assessment_components")
}

model VisiMisi {
  id             String        @id @default(uuid())
  type           VisiMisiType
  content        String
  curriculumYear Int
  orderNumber    Int           @default(1)
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([type])
  @@index([curriculumYear])
  @@index([isActive])
  @@map("visi_misi")
}

model GraduateProfile {
  id                 String               @id @default(uuid())
  code               String               @unique
  name               String
  description        String?
  vision             String?
  mission            String?
  curriculumYear     Int
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  cpls               Cpl[]
  cplProfileMappings CplProfileMapping[]

  @@index([code])
  @@index([name])
  @@index([curriculumYear])
  @@map("graduate_profiles")
}

model Cpl {
  id                String           @id @default(uuid())
  code              String           @unique
  name              String
  category          CplCategory
  description       String?
  curriculumYear    Int
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  graduateProfileId String?
  graduateProfile   GraduateProfile? @relation(fields: [graduateProfileId], references: [id], onDelete: SetNull)
  cplMappings        CplBahanKajianMapping[]
  cpmkMappings       CpmkCplMapping[]
  cplProfileMappings CplProfileMapping[]
  cplBkMappings      CplBodyOfKnowledgeMapping[]

  @@index([code])
  @@index([name])
  @@index([category])
  @@index([isActive])
  @@index([curriculumYear])
  @@index([graduateProfileId])
  @@map("cpl")
}

model BahanKajian {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  curriculumYear Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cplMappings CplBahanKajianMapping[]

  @@index([code])
  @@index([name])
  @@index([curriculumYear])
  @@map("bahan_kajian")
}

model CplBahanKajianMapping {
  id            String      @id @default(uuid())
  cplId         String
  bahanKajianId String
  createdAt     DateTime    @default(now())
  cpl           Cpl         @relation(fields: [cplId], references: [id], onDelete: Cascade)
  bahanKajian   BahanKajian @relation(fields: [bahanKajianId], references: [id], onDelete: Cascade)

  @@unique([cplId, bahanKajianId])
  @@index([cplId])
  @@index([bahanKajianId])
  @@map("cpl_bahan_kajian_mappings")
}

model Cpmk {
  id             String                       @id @default(uuid())
  curriculumId   String
  code           String
  name           String
  description    String?
  isActive       Boolean                      @default(true)
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
  cpmkMappings   CpmkCplMapping[]
  subCpmks       SubCpmk[]
  courseMappings CpmkCourseMapping[]
  weightEntries  CourseCpmkAssessmentWeight[]

  @@unique([curriculumId, code])
  @@index([curriculumId])
  @@index([code])
  @@map("cpmk")
}

model CpmkCourseMapping {
  id       String @id @default(uuid())
  cpmkId   String
  courseId String
  cpmk     Cpmk   @relation(fields: [cpmkId], references: [id], onDelete: Cascade)

  @@unique([cpmkId, courseId])
  @@index([cpmkId])
  @@index([courseId])
  @@map("cpmk_course_mapping")
}

model SubCpmk {
  id               String       @id @default(uuid())
  curriculumId     String
  courseId         String
  cpmkId           String
  code             String
  name             String
  description      String?
  orderNumber      Int          @default(0)
  targetPercentage Int          @default(0)
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  cpmk             Cpmk         @relation(fields: [cpmkId], references: [id], onDelete: Cascade)
  assessments      Assessment[]

  @@unique([courseId, cpmkId, code])
  @@index([curriculumId])
  @@index([courseId])
  @@index([cpmkId])
  @@index([code])
  @@map("sub_cpmk")
}

model Assessment {
  id          String         @id @default(uuid())
  subCpmkId   String
  code        String
  name        String
  description String?
  type        AssessmentType
  weight      Int
  maxScore    Int
  orderNumber Int
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  subCpmk     SubCpmk        @relation(fields: [subCpmkId], references: [id], onDelete: Cascade)
  rubrics     Rubric[]

  @@unique([code, subCpmkId])
  @@index([code])
  @@index([subCpmkId])
  @@index([type])
  @@index([orderNumber])
  @@map("assessments")
}

model Rubric {
  id          String     @id @default(uuid())
  assessmentId String
  code        String
  name        String
  description String?
  weight      Int
  maxScore    Int
  orderNumber Int
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  assessment  Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([code, assessmentId])
  @@index([code])
  @@index([assessmentId])
  @@index([orderNumber])
  @@map("rubrics")
}

model CpmkCplMapping {
  id        String   @id @default(uuid())
  cpmkId    String
  cplId     String
  weight    Int
  createdAt DateTime @default(now())
  cpmk      Cpmk     @relation(fields: [cpmkId], references: [id], onDelete: Cascade)
  cpl       Cpl      @relation(fields: [cplId], references: [id], onDelete: Cascade)

  @@unique([cpmkId, cplId])
  @@index([cpmkId])
  @@index([cplId])
  @@map("cpmk_cpl_mappings")
}

model BodyOfKnowledge {
  id           String   @id @default(uuid())
  curriculumId String
  code         String
  name         String
  reference    String?
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  cplBkMappings    CplBodyOfKnowledgeMapping[]
  bkCourseMappings BkCourseMapping[]

  @@unique([curriculumId, code])
  @@index([curriculumId])
  @@index([code])
  @@index([name])
  @@index([isActive])
  @@map("body_of_knowledges")
}

model BkCourseMapping {
  id                String          @id @default(uuid())
  curriculumId      String
  bodyOfKnowledgeId String
  courseId          String
  createdAt         DateTime        @default(now())
  bodyOfKnowledge   BodyOfKnowledge @relation(fields: [bodyOfKnowledgeId], references: [id], onDelete: Cascade)

  @@unique([curriculumId, bodyOfKnowledgeId, courseId])
  @@index([curriculumId])
  @@index([bodyOfKnowledgeId])
  @@index([courseId])
  @@map("bk_course_mappings")
}

model CplProfileMapping {
  id                String          @id @default(uuid())
  curriculumId      String
  cplId             String
  graduateProfileId String
  createdAt         DateTime        @default(now())
  cpl               Cpl             @relation(fields: [cplId], references: [id], onDelete: Cascade)
  graduateProfile   GraduateProfile @relation(fields: [graduateProfileId], references: [id], onDelete: Cascade)

  @@unique([curriculumId, cplId, graduateProfileId])
  @@index([curriculumId])
  @@index([cplId])
  @@index([graduateProfileId])
  @@map("cpl_profile_mappings")
}

model CplBodyOfKnowledgeMapping {
  id                String          @id @default(uuid())
  curriculumId      String
  cplId             String
  bodyOfKnowledgeId String
  createdAt         DateTime        @default(now())
  cpl               Cpl             @relation(fields: [cplId], references: [id], onDelete: Cascade)
  bodyOfKnowledge   BodyOfKnowledge @relation(fields: [bodyOfKnowledgeId], references: [id], onDelete: Cascade)

  @@unique([curriculumId, cplId, bodyOfKnowledgeId])
  @@index([curriculumId])
  @@index([cplId])
  @@index([bodyOfKnowledgeId])
  @@map("cpl_body_of_knowledge_mappings")
}

model CourseCpmkAssessmentWeight {
  id                    String              @id @default(uuid())
  courseId              String
  cpmkId                String
  assessmentComponentId String
  weight                Int                 @default(0)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  cpmk                  Cpmk                @relation(fields: [cpmkId], references: [id], onDelete: Cascade)
  assessmentComponent   AssessmentComponent @relation(fields: [assessmentComponentId], references: [id], onDelete: Cascade)

  @@unique([courseId, cpmkId, assessmentComponentId])
  @@index([courseId])
  @@index([cpmkId])
  @@index([assessmentComponentId])
  @@map("course_cpmk_assessment_weights")
}
