# =============================================================================
# SYTAMA Production — Environment Variables
# Copy file ini ke /root/sytama/.env di VPS dan isi nilainya
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
PG_DB=authentik
PG_USER=authentik
PG_PASS=GANTI_PASSWORD_KUAT_DI_SINI

# ── Authentik SSO ─────────────────────────────────────────────────────────────
# Generate dengan: openssl rand -base64 60
AUTHENTIK_SECRET_KEY=GANTI_SECRET_KEY_MINIMAL_50_KARAKTER_DI_SINI

AUTHENTIK_BOOTSTRAP_EMAIL=admin@widyatama.ac.id
AUTHENTIK_BOOTSTRAP_PASSWORD=GANTI_PASSWORD_ADMIN_DI_SINI

# Didapat dari Authentik Admin → System → Tokens (setelah Authentik jalan)
AUTHENTIK_ADMIN_TOKEN=

# ── OAuth2 Client Secret (sama untuk semua app) ────────────────────────────────
VITE_AUTHENTIK_CLIENT_SECRET=GANTI_CLIENT_SECRET_DI_SINI
