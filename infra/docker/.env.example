# =============================================================================
# Docker Compose Environment Variables
# =============================================================================
# Copy this file to .env and adjust as needed:
#   cp .env.example .env
# =============================================================================

# PostgreSQL password for Authentik
PG_PASS=authentik

# Authentik secret key (must be at least 50 characters)
# Change this in production!
AUTHENTIK_SECRET_KEY=change-me-to-a-secure-key-at-least-50-characters-long

# Authentik ports (change if you have conflicts)
AUTHENTIK_PORT_HTTP=9010
AUTHENTIK_PORT_HTTPS=9444
