# Database Configuration
DATABASE_URL=postgresql://akademik_user:akademik_pass@localhost:5432/akademik_db

# SSO Configuration (Authentik)
AUTHENTIK_ISSUER_URL=http://localhost:9000/application/o/widyatama/
AUTHENTIK_CLIENT_ID_DOSEN=your-dosen-client-id
AUTHENTIK_CLIENT_SECRET_DOSEN=your-dosen-client-secret
AUTHENTIK_CLIENT_ID_MAHASISWA=your-mahasiswa-client-id
AUTHENTIK_CLIENT_SECRET_MAHASISWA=your-mahasiswa-client-secret
AUTHENTIK_CLIENT_ID_AKADEMIK=your-akademik-client-id
AUTHENTIK_CLIENT_SECRET_AKADEMIK=your-akademik-client-secret
AUTHENTIK_CLIENT_ID_IDENTITY=fe-identity
AUTHENTIK_CLIENT_SECRET_IDENTITY=your-identity-client-secret

# Auth Configuration
JWT_SECRET=your-super-secret-jwt-key

# API URLs
API_NILAI_URL=http://localhost:3001
API_KEHADIRAN_URL=http://localhost:3002
API_IDENTITY_URL=http://localhost:3003

# Frontend URLs
FE_DOSEN_URL=http://localhost:3010
FE_MAHASISWA_URL=http://localhost:3011
FE_AKADEMIK_URL=http://localhost:3012

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Environment
NODE_ENV=development
