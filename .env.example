# Database Configuration
DATABASE_URL=postgresql://akademik_user:akademik_pass@localhost:5432/akademik_db

# SSO Configuration (Zitadel)
ZITADEL_ISSUER_URL=https://your-instance.zitadel.cloud
ZITADEL_CLIENT_ID=your-client-id
ZITADEL_CLIENT_SECRET=your-client-secret

# Auth Configuration
JWT_SECRET=your-super-secret-jwt-key
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# API URLs
API_NILAI_URL=http://localhost:3001
API_KEHADIRAN_URL=http://localhost:3002
API_IDENTITY_URL=http://localhost:3003

# Frontend URLs
FE_DOSEN_URL=http://localhost:3010
FE_MAHASISWA_URL=http://localhost:3011
FE_AKADEMIK_URL=http://localhost:3012

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Environment
NODE_ENV=development
