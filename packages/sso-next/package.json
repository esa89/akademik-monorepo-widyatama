{
  "name": "@widyatama/sso-next",
  "version": "1.0.0",
  "description": "SSO utilities for Next.js frontends (Authentik OIDC)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "next-auth": "^4.24.0",
    "@widyatama/sso-types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "rimraf": "^5.0.0",
    "next": "^14.0.0",
    "react": "^18.0.0"
  },
  "peerDependencies": {
    "next": "^13.0.0 || ^14.0.0",
    "react": "^18.0.0",
    "next-auth": "^4.20.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**/*"
